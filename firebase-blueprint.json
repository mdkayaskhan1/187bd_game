{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user balance and basic info",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "username": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "referrerId": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "notifications": { "type": "boolean" },
            "theme": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "balance"]
    },
    "Referral": {
      "title": "Referral Record",
      "description": "Tracks referrals between users",
      "type": "object",
      "properties": {
        "referrerId": { "type": "string" },
        "referredUserId": { "type": "string" },
        "bonusClaimed": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["referrerId", "referredUserId", "timestamp"]
    },
    "Bet": {
      "title": "Bet History",
      "description": "Records of individual bets",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "game": { "type": "string", "enum": ["crash", "mines", "slots"] },
        "betAmount": { "type": "number" },
        "multiplier": { "type": "number" },
        "payout": { "type": "number" },
        "win": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "game", "betAmount", "timestamp"]
    },
    "Transaction": {
      "title": "Transaction Record",
      "description": "Deposit and withdrawal records",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "method": { "type": "string" },
        "accountNumber": { "type": "string" },
        "transactionId": { "type": "string" },
        "proofUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "type", "amount", "status", "timestamp", "method"]
    },
    "Profile": {
      "title": "Public Profile",
      "description": "Publicly accessible user info for leaderboard",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "username": { "type": "string" },
        "photoURL": { "type": "string" },
        "balance": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["balance"]
    },
    "Jackpot": {
      "title": "Progressive Jackpot",
      "description": "Global jackpot pool",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "lastWinner": { "type": "string" },
        "lastWinAmount": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Real-time chat message",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "text", "timestamp"]
    },
    "Notification": {
      "title": "User Notification",
      "description": "System and user-specific notifications",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "bonus", "alert", "success"] },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "message", "type", "timestamp"]
    },
    "DailyBonus": {
      "title": "Daily Bonus Record",
      "description": "Tracks when a user last claimed their daily bonus",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "totalClaimed": { "type": "number" },
        "lastClaimed": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "lastClaimed"]
    },
    "CrashHistory": {
      "title": "Crash Game History",
      "description": "Records of crash game multipliers",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "multiplier": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "multiplier", "timestamp"]
    }
  },
  "firestore": {
    "/chat/{messageId}": {
      "schema": "ChatMessage",
      "description": "Global chat messages"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/jackpot/global": {
      "schema": "Jackpot",
      "description": "Global progressive jackpot pool"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/profiles/{userId}": {
      "schema": "Profile",
      "description": "Public user profiles"
    },
    "/bets/{betId}": {
      "schema": "Bet",
      "description": "Global bet history"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transactions"
    },
    "/daily_bonus/{bonusId}": {
      "schema": "DailyBonus",
      "description": "Daily bonus claim history"
    },
    "/referrals/{referralId}": {
      "schema": "Referral",
      "description": "Referral tracking"
    },
    "/crash_history/{historyId}": {
      "schema": "CrashHistory",
      "description": "Crash game history"
    }
  }
}
