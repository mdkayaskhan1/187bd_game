rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - email: string
    //   - balance: number (required, >= 0)
    //   - createdAt: timestamp
    //
    // Collection: bets
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required)
    //   - game: string (required, enum: crash, mines, slots)
    //   - betAmount: number (required, > 0)
    //   - multiplier: number
    //   - payout: number
    //   - win: boolean
    //   - timestamp: timestamp (required)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.get('uid', request.auth.uid) == request.auth.uid &&
             data.balance is number && data.balance >= 0 &&
             (!('email' in data) || data.email is string) &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('username' in data) || data.username is string) &&
             (!('settings' in data) || data.settings is map);
    }

    function isValidProfile(data) {
      return (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('username' in data) || (data.username is string && data.username.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 200000)) &&
             (!('balance' in data) || data.balance is number);
    }

    function isValidBet(data) {
      return data.get('uid', request.auth.uid) == request.auth.uid &&
             data.game in ['crash', 'mines', 'slots', 'plinko', 'tower', 'dice', 'limbo', 'aviator', 'slots2'] &&
             data.betAmount is number && data.betAmount > 0 &&
             data.timestamp is timestamp;
    }

    function isValidTransaction(data) {
      return data.get('uid', request.auth.uid) == request.auth.uid &&
             data.type in ['deposit', 'withdrawal'] &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending', 'completed', 'failed', 'rejected'] &&
             data.method is string &&
             data.timestamp is timestamp &&
             (!('accountNumber' in data) || data.accountNumber is string);
    }

    function isValidChatMessage(data) {
      return data.uid == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() < 500 &&
             data.timestamp is timestamp &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL is string);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "mdkayaskhan923@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /jackpot/global {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
    }

    match /profiles/{userId} {
      // Public profiles for leaderboard
      allow read: if true;
      allow write: if isOwner(userId) && isValidProfile(request.resource.data);
    }

    match /bets/{betId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBet(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /chat/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidChatMessage(request.resource.data);
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
